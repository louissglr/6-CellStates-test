rule recap_patterns_global:
    input:
        cogaps_files=lambda wildcards: [
            config["cogapsOutDir"] + f"/{wildcards.sample}/cogaps/patterns_{SAMPLE_PATTERNS[wildcards.sample]}/object/{wildcards.sample}.npatterns-{SAMPLE_PATTERNS[wildcards.sample]}.cogaps-object.Rds"
        ]
    output:
        csv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_recap_global.csv"
    conda:
        "envs/cogaps.yml"
    threads: 1
    script:
        "scripts/recap_patterns_global.R"

    

