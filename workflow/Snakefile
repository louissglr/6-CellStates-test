rule umap_dominant:
    input:
        contributions=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
        umap=lambda wildcards: (
            config["cooDir_combined"] + f"/{wildcards.sample}/{wildcards.sample}.scrnaseq.icagen-filtered.normalized-sctransform-v2.umap-coords.tsv"
            if wildcards.dataset == "scrnaseq"
            else config["cooDir_combined"] + f"/{wildcards.sample}/{wildcards.sample}.scatacseq.icagen-filtered.umap-coords.tsv"
            if wildcards.dataset == "scatacseq"
            else config["cooDir_multimodal"] + f"/{wildcards.sample}/seurat-multimodal/dims8-8/umaps/coords-multimodal-umap_dims8-8.tsv"
            if wildcards.dataset == "multimodal"
            else config["cogapsOutDir"] + f"/{wildcards.sample}/cogaps/patterns_{wildcards.npatterns}/umap/coo/{wildcards.sample}.npatterns-{wildcards.npatterns}.nmf.umap-coords.txt"
        )
    output:
        png=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/dominant/{sample}.npatterns-{npatterns}.UMAP_dominant_{dataset}.png"
    params:
        dataset="{dataset}"
    wildcard_constraints:
        dataset="scrnaseq|scatacseq|multimodal|nmf"
    conda:
        "envs/cogaps.yml"
    script:
        "scripts/plot_umap_dominant.R"


rule umap_weight:
    input:
        contributions=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
        umap=lambda wildcards: (
            config["cooDir_combined"] + f"/{wildcards.sample}/{wildcards.sample}.scrnaseq.icagen-filtered.normalized-sctransform-v2.umap-coords.tsv"
            if wildcards.dataset == "scrnaseq"
            else config["cooDir_combined"] + f"/{wildcards.sample}/{wildcards.sample}.scatacseq.icagen-filtered.umap-coords.tsv"
            if wildcards.dataset == "scatacseq"
            else config["cooDir_multimodal"] + f"/{wildcards.sample}/seurat-multimodal/dims8-8/umaps/coords-multimodal-umap_dims8-8.tsv"
            if wildcards.dataset == "multimodal"
            else config["cogapsOutDir"] + f"/{wildcards.sample}/cogaps/patterns_{wildcards.npatterns}/umap/coo/{wildcards.sample}.npatterns-{wildcards.npatterns}.nmf.umap-coords.txt"
        )
    output:
        png=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/weight/{sample}.npatterns-{npatterns}.UMAP_weight_{dataset}.png"
    params:
        dataset="{dataset}"
    wildcard_constraints:
        dataset="scrnaseq|scatacseq|multimodal|nmf"
    conda:
        "envs/cogaps.yml"
    script:
        "scripts/plot_umap_weight.R"


rule nb_cells:
    input:
        contrib=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
        subclones=config["subcloneDir"] + "/{sample}/seurat-multimodal_vars30-30/clusters/clusters_vars30-30_res0.4.tsv",
    output:
        png1=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/dominant/infos/{sample}.npatterns-{npatterns}.nb_cells_bysubclones.png",
        png2=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/dominant/infos/{sample}.npatterns-{npatterns}.nb_cells_bypatterns.png"
    conda:
        "envs/cogaps.yml"
    threads: 1
    script:
        "scripts/plot_nb_cells.R"


rule pathway_activity_maya:
    input:
        seurat=config["dataDir"] + "/{sample}/{sample}.scrnaseq.icagen-filtered.seurat-object.Rds",
