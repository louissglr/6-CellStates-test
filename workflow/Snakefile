import pandas as pd

configfile: "../config/config-glicid-scratch.yml"

# ---------------------------------------------------------------------------
# Read TSV of samples - patterns to test 
# ---------------------------------------------------------------------------
samples_df = pd.read_csv(config["patternsPerSample"], sep="\t", dtype={"sample": str, "nb_patterns": int})

# Dictionarie  {sample : nb_patterns} 
all_sample_patterns = dict(zip(samples_df["sample"], samples_df["nb_patterns"]))

SAMPLES = config["samples"] #samples to test

SAMPLE_PATTERNS = {s: all_sample_patterns[s] for s in SAMPLES} #keep only samples in the tsv files


# ---------------------------------------------------------------------------
# Function to generate outputs files for rule all()
# ---------------------------------------------------------------------------
def all_outputs():
    outputs = []
    for sample, npatterns in SAMPLE_PATTERNS.items(): #iterable object

        s = sample
        n = npatterns
        base = config["cogapsOutDir"] + f"/{s}/cogaps/patterns_{n}"
        prefix = f"{s}.npatterns-{n}"

        # Markers Excel
        outputs.append(f"{base}/markers/{prefix}.markers.xlsx")

        # Contributions
        outputs.append(f"{base}/contributions/{prefix}.contributions_cells.txt")
        outputs.append(f"{base}/contributions/{prefix}.contributions_genes.txt")

        # Pattern specificity PDF
        outputs.append(f"{base}/specificity/{prefix}.patterns_specificity.pdf")

        # Hallmarks enrichment & overrepresentation CSVs
        outputs.append(f"{base}/hallmarks/get_function/enrichment/{prefix}.hallmarks_enrichment.csv")
        outputs.append(f"{base}/hallmarks/get_function/overrep/{prefix}.hallmarks_overrepresentation.csv")
        outputs.append(f"{base}/hallmarks/manually/enrichment/{prefix}.hallmarks_enrichment.csv")
        outputs.append(f"{base}/hallmarks/manually/overrep/{prefix}.hallmarks_overrepresentation.csv")

        # Hallmarks unique PDFs
        outputs.append(f"{base}/hallmarks/get_function/enrichment/{prefix}.hallmarks_enrichment_unique.pdf")
        outputs.append(f"{base}/hallmarks/get_function/overrep/{prefix}.hallmarks_overrepresentation_unique.pdf")

        # Hallmarks PDFs
        outputs.append(f"{base}/hallmarks/get_function/enrichment/{prefix}.hallmarks_enrichment.pdf")
        outputs.append(f"{base}/hallmarks/get_function/overrep/{prefix}.hallmarks_overrepresentation.pdf")

        # Intersection hallmarks
        outputs.append(f"{base}/hallmarks/get_function/enrichment/{prefix}.intersection_hallmarks_enrichment.pdf")
        outputs.append(f"{base}/hallmarks/get_function/overrep/{prefix}.intersection_hallmarks_overrepresentation.pdf")
        outputs.append(f"{base}/hallmarks/get_function/enrichment/{prefix}.intersection_hallmarks_enrichment.csv")
        outputs.append(f"{base}/hallmarks/get_function/overrep/{prefix}.intersection_hallmarks_overrepresentation.csv")

        # Statistics
        outputs.append(f"{base}/statistics/{prefix}.kw_results.csv")
        outputs.append(f"{base}/statistics/{prefix}.pairwise_results.csv")

        # Heatmaps
        outputs.append(f"{base}/markers/{prefix}.heatmaps.pdf")
        outputs.append(f"{base}/hallmarks/get_function/enrichment/{prefix}.hallmarks_enrichment_heatmap.pdf")
        outputs.append(f"{base}/hallmarks/get_function/overrep/{prefix}.hallmarks_overrepresentation_heatmap.pdf")
        outputs.append(f"{base}/hallmarks/manually/enrichment/{prefix}.hallmarks_enrichment_heatmap.pdf")
        outputs.append(f"{base}/hallmarks/manually/overrep/{prefix}.hallmarks_overrepresentation_heatmap.pdf")

        # UMAP dominant
        for dataset in ["scrnaseq", "scatacseq", "multimodal", "nmf"]:
            outputs.append(f"{base}/umap/dominant/{prefix}.UMAP_dominant_{dataset}.pdf")

        # UMAP nb_cells
        outputs.append(f"{base}/umap/dominant/infos/{prefix}.nb_cells.pdf")

        # UMAP coords NMF
        outputs.append(f"{base}/umap/coo/{prefix}.nmf.umap-coords.txt")

        # UMAP weight
        for dataset in ["scrnaseq", "scatacseq", "multimodal", "nmf"]:
            outputs.append(f"{base}/umap/weight/{prefix}.UMAP_weight_{dataset}.pdf")

#        outputs.append(config["cogapsOutDir"] + f"/{s}/cogaps/clustree/clustree_table.tsv")
#        outputs.append(config["cogapsOutDir"] + f"/{s}/cogaps/clustree/clustree.pdf")

        # Recap global (par sample)
        outputs.append(config["cogapsOutDir"] + f"/{s}/cogaps/patterns_recap_global.csv")

    # Maya (par sample uniquement, pas de npatterns)
    for sample in SAMPLES:
        maya_base = config["mayaOutDir"] + f"/{sample}/maya"
        outputs.append(f"{maya_base}/heatmap_cluster_cols_rows.png")
        outputs.append(f"{maya_base}/heatmap_cluster_rows_only.png")
        outputs.append(f"{maya_base}/umap_clone_annotation.png")
        outputs.append(f"{maya_base}/ALL_modules_top_contrib_genes.pdf")
        outputs.append(f"{maya_base}/ALL_modules_specificity.pdf")

    # Dédoublonnage (clustree / recap apparaissent une fois par sample)
    return list(dict.fromkeys(outputs))


# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

rule all:
    input:
        all_outputs()


rule cogaps:
    input:
        tumor_rna_seuratobj=config["dataDir"] + "/{sample}/{sample}.scrnaseq.icagen-filtered.seurat-object.Rds"
    output:
        cogaps_rds=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/object/{sample}.npatterns-{npatterns}.cogaps-object.Rds"
    log:
        "logs/{sample}/{sample}-{npatterns}.log"
    benchmark:
        "benchmarks/{sample}/{sample}-{npatterns}.tsv"
    conda:
        "envs/cogaps.yml"
    threads: 65
    params:
        npatterns="{npatterns}",
        nIterations=config["cogapsIterations"]
    script:
        "scripts/run_cogaps.R"


rule reduce_dim_cogaps:
    input:
        contrib_tsv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
    output:
        tsv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/coo/{sample}.npatterns-{npatterns}.nmf.umap-coords.txt",
    conda:
        "envs/cogaps.yml"
    threads: 1
    script:
        "scripts/reduce_dim.R"


