    output:
        heatmap1=config["mayaOutDir"] + "/{sample}/maya/heatmap_cluster_cols_rows.png",
        heatmap2=config["mayaOutDir"] + "/{sample}/maya/heatmap_cluster_rows_only.png",
        umap=config["mayaOutDir"] + "/{sample}/maya/umap_clone_annotation.png",
        top_genes=config["mayaOutDir"] + "/{sample}/maya/ALL_modules_top_contrib_genes.pdf",
        specificity=config["mayaOutDir"] + "/{sample}/maya/ALL_modules_specificity.pdf"
    conda:
        "envs/maya.yml"
    threads: 1
    script:
        "scripts/pathway_activity_maya.R"


rule dominant_patterns_summary:
    input:
        lambda wildcards: expand(
            config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
            sample=wildcards.sample,
            npatterns=SAMPLE_PATTERNS[wildcards.sample]
        )
    output:
        tsv=config["cogapsOutDir"] + "/{sample}/cogaps/clustree/clustree_table.tsv"
    conda:
        "envs/cogaps.yml"
    script:
        "scripts/dominant_patterns_summary.R"


