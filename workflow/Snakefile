    script:
        "scripts/pathway_activity_maya.R"


rule dominant_patterns_summary:
    input:
        lambda wildcards: expand(
            config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
            sample=wildcards.sample,
            npatterns=SAMPLE_PATTERNS[wildcards.sample]
        )
    output:
        tsv=config["cogapsOutDir"] + "/{sample}/cogaps/clustree/clustree_table.tsv"
    conda:
        "envs/cogaps.yml"
    script:
        "scripts/dominant_patterns_summary.R"


